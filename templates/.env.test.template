# ==============================================================================
# {{PROJECT_NAME}} - TEST ENVIRONMENT (.env.test)
# ==============================================================================
# 테스트 실행용 환경설정
# npm run test, npm run test:e2e 에서 사용
# ==============================================================================

# Server
PORT=3555
NODE_ENV=test
NEXT_PUBLIC_BASE_URL=http://localhost:3555
BASE_URL=http://localhost:3555

# Database (테스트 전용 DB - 격리)
DATABASE_URL=postgresql://postgres:password@localhost:5432/{{PROJECT_NAME}}_test
DIRECT_URL=postgresql://postgres:password@localhost:5432/{{PROJECT_NAME}}_test

# Redis Cache (테스트는 InMemory만)
CACHE_ENABLED=true
CACHE_REDIS_ENABLED=false
CACHE_INMEMORY_ENABLED=true

# JWT (테스트용 고정 시크릿)
JWT_SECRET=test-jwt-secret-key-for-testing-purposes-32ch
JWT_REFRESH_SECRET=test-refresh-secret-key-for-testing-32char
JWT_EXPIRES_IN=1h
JWT_REFRESH_TOKEN_EXPIRES_IN=2h

# Rate Limiting (테스트에서는 비활성화)
RATE_LIMIT_ENABLED=false

# Logging (테스트에서는 최소화)
LOG_LEVEL=error
LOG_CONSOLE_ENABLED=false
LOG_FILE_ENABLED=false

# Test Specific
TEST_MODE=true
