# ==============================================================================
# {{PROJECT_NAME}} - PRODUCTION ENVIRONMENT (.env.production)
# ==============================================================================
# 프로덕션 서버용 환경설정
# npm run build && npm run start 으로 사용
# ==============================================================================

# Server
PORT=3000
NODE_ENV=production
NEXT_PUBLIC_BASE_URL=https://{{PROJECT_DOMAIN}}
BASE_URL=https://{{PROJECT_DOMAIN}}

# Database (프로덕션 DB)
DATABASE_URL=postgresql://user:password@prod-db-host:6543/{{PROJECT_NAME}}?pgbouncer=true
DIRECT_URL=postgresql://user:password@prod-db-host:5432/{{PROJECT_NAME}}

# Redis Cache (Upstash 프로덕션)
UPSTASH_REDIS_REST_URL=https://prod-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=prod_token_here
CACHE_ENABLED=true
CACHE_REDIS_ENABLED=true
CACHE_INMEMORY_ENABLED=true
CACHE_FALLBACK_ON_REDIS_ERROR=true

# JWT (프로덕션 - 강력한 시크릿 필수!)
JWT_SECRET=production-super-secure-jwt-secret-minimum-32-chars
JWT_REFRESH_SECRET=production-super-secure-refresh-secret-32chars
JWT_EXPIRES_IN=1d
JWT_REFRESH_TOKEN_EXPIRES_IN=7d

# OAuth (프로덕션 클라이언트)
GOOGLE_CLIENT_ID=prod-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=prod-google-secret
GITHUB_ID=prod-github-client-id
GITHUB_SECRET=prod-github-secret

# Rate Limiting (프로덕션 - 엄격한 설정)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_API=120
RATE_LIMIT_AUTH=40
RATE_LIMIT_ADMIN=200

# Logging
LOG_LEVEL=warn
LOG_CONSOLE_ENABLED=true
LOG_FILE_ENABLED=true
LOG_DIR=./logs

# Security
BCRYPT_ROUNDS=12
ALLOWED_ORIGINS=https://{{PROJECT_DOMAIN}},https://www.{{PROJECT_DOMAIN}}
