# ==============================================================================
# {{PROJECT_NAME}} - DEVELOPMENT ENVIRONMENT (.env.dev)
# ==============================================================================
# 개발 서버용 환경설정 (공유 개발 환경)
# npm run dev 명령어로 사용
# ==============================================================================

# Server
PORT=3000
NODE_ENV=development
NEXT_PUBLIC_BASE_URL=https://dev.{{PROJECT_DOMAIN}}
BASE_URL=https://dev.{{PROJECT_DOMAIN}}

# Database (개발 DB - Supabase 등)
DATABASE_URL=postgresql://user:password@dev-db-host:6543/{{PROJECT_NAME}}_dev?pgbouncer=true
DIRECT_URL=postgresql://user:password@dev-db-host:5432/{{PROJECT_NAME}}_dev

# Redis Cache (Upstash 개발 인스턴스)
UPSTASH_REDIS_REST_URL=https://dev-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=dev_token_here
CACHE_ENABLED=true
CACHE_REDIS_ENABLED=true
CACHE_INMEMORY_ENABLED=true

# JWT (개발용)
JWT_SECRET=dev-jwt-secret-key-at-least-32-characters-long
JWT_REFRESH_SECRET=dev-refresh-secret-key-at-least-32-characters
JWT_EXPIRES_IN=7d
JWT_REFRESH_TOKEN_EXPIRES_IN=30d

# OAuth (개발용 클라이언트)
GOOGLE_CLIENT_ID=dev-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=dev-google-secret
GITHUB_ID=dev-github-client-id
GITHUB_SECRET=dev-github-secret

# Rate Limiting (개발 환경 - 완화된 설정)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_API=200
RATE_LIMIT_AUTH=100

# Logging
LOG_LEVEL=info
LOG_CONSOLE_ENABLED=true
LOG_FILE_ENABLED=true
LOG_DIR=./logs
